flowchart TD
    subgraph INIT["main.rs 系统初始化"]
        A["embassy_stm32::init()"] --> B["配置 I2C2 总线<br/>PB10(SCL) / PB11(SDA)<br/>Blocking 模式"]
        B --> C["创建 I2C2 共享总线<br/>Mutex + RefCell"]
        C --> D["spawner.spawn() 分发任务"]
    end

    subgraph SHT30["SHT30 采集任务 (1Hz)"]
        direction TB
        E1["sht30_task()"] --> E2["发送软复位命令 0x30A2"]
        E2 --> E3["Ticker::every(1s)"]
        E3 --> E4["发送测量命令 0x2400<br/>High Repeatability"]
        E4 --> E5["Timer::after(20ms)"]
        E5 --> E6["I2C 读取 6 字节<br/>[T_msb, T_lsb, T_crc,<br/> H_msb, H_lsb, H_crc]"]
        E6 --> E7{"CRC-8 校验<br/>多项式 0x31"}
        E7 -->|失败| E8["fail_count += 1"]
        E8 --> E9{"fail_count >= 3?"}
        E9 -->|是| E10["写入 None<br/>标记传感器离线"]
        E9 -->|否| E3
        E7 -->|成功| E11["温度: -45+175×raw/65535<br/>湿度: 100×raw/65535"]
        E11 --> E12["GLOBAL_STATE.lock()<br/>写入 temperature, humidity_air"]
        E12 --> E3
    end

    subgraph BH1750["BH1750 采集任务 (1Hz)"]
        direction TB
        F1["bh1750_task()"] --> F2["发送通电指令 0x01"]
        F2 --> F3["设置连续高分辨率模式 0x10"]
        F3 --> F4["Ticker::every(1s)"]
        F4 --> F5["I2C 读取 2 字节<br/>[MSB, LSB]"]
        F5 --> F6["光照强度 = raw / 1.2 Lux"]
        F6 --> F7["GLOBAL_STATE.lock()<br/>写入 light_intensity"]
        F7 --> F4
    end

    subgraph SOIL["土壤湿度采集任务 (1Hz)"]
        direction TB
        G1["soil_moisture_task()"] --> G2["ADC1 采样 PC1 引脚"]
        G2 --> G3["读取 VREFINT 校准电压"]
        G3 --> G4["湿度% = (4000-raw)/(4000-1000)×100"]
        G4 --> G5["GLOBAL_STATE.lock()<br/>写入 humidity_soil"]
        G5 --> H1["Timer::after(1s)"]
        H1 --> G2
    end

    subgraph GLOBAL["GLOBAL_STATE<br/>Mutex 共享状态"]
        GS["CurrentValues {<br/>  temperature: Option-f32-<br/>  humidity_air: Option-f32-<br/>  humidity_soil: Option-f32-<br/>  light_intensity: Option-f32-<br/>  ...<br/>}"]
    end

    subgraph DISPATCH["调度器任务 (2Hz)"]
        direction TB
        I1["dispatcher_task()"] --> I2["Ticker::every(500ms)"]
        I2 --> I3["读取 GLOBAL_STATE 快照"]
        I3 --> I4{"control_mode == Auto?"}
        I4 -->|否| I2
        I4 -->|是| I5["迟滞比较: 温度/湿度/土壤/光照"]
        I5 --> I6["计算风扇转速 / PWM 占空比"]
        I6 --> I7["写入 TargetValues 到 GLOBAL_STATE"]
        I7 --> I2
    end

    subgraph CANTX["CAN 发送任务 (1Hz)"]
        direction TB
        J1["can_tx_task()"] --> J2["Ticker::every(1s)"]
        J2 --> J3["GLOBAL_STATE.lock()<br/>快照 CurrentValues"]
        J3 --> J4["f32 缩放为 u32<br/>×100 或 ×1"]
        J4 --> J5["build_tx_frame()<br/>ID = func_code<<7 | NODE_ID"]
        J5 --> J6["CAN1 发送 8 字节帧"]
        J6 --> J2
    end

    D --> E1
    D --> F1
    D --> G1
    D --> I1
    D --> J1

    E12 --> GS
    F7 --> GS
    G5 --> GS
    GS --> I3
    GS --> J3
    I7 --> GS
